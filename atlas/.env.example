# ATLAS Environment Configuration
# Copy this to .env and fill in your values
# Store secrets in ~/.atlas/.secrets/ for production

# ──────────────────────────────────────────────
# CHANNELS (Messaging)
# ──────────────────────────────────────────────

# Telegram (primary channel)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ATLAS_OWNER_TELEGRAM_ID=your_telegram_user_id
ATLAS_OWNER_USERNAME=your_telegram_username

# Discord (optional)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Slack (optional)
SLACK_BOT_TOKEN=your_slack_bot_token_here

# ──────────────────────────────────────────────
# AI PROVIDERS (provider chain: NIM → OpenRouter → Anthropic → Ollama)
# ──────────────────────────────────────────────

# NVIDIA NIM (free tier — kimi-k2.5 / Qwen3.5)
NVIDIA_API_KEY=your_nvidia_api_key_here

# OpenRouter (fallback — $0.60/$3.00 per M)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Anthropic (premium — complex reasoning — $5/$25 per M)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Ollama (local / free — offline fallback)
OLLAMA_API_KEY=your_ollama_api_key_here
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI (embeddings only, optional)
OPENAI_API_KEY=your_openai_api_key_here

# ──────────────────────────────────────────────
# OPERATOR
# ──────────────────────────────────────────────

ATLAS_TIMEZONE=America/New_York
ATLAS_WORK_HOURS_START=09:00
ATLAS_WORK_HOURS_END=18:00

# ──────────────────────────────────────────────
# WEBHOOKS (atlas/tools/webhooks/server.py)
# ──────────────────────────────────────────────

GITHUB_WEBHOOK_SECRET=your_github_webhook_secret
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
WEBHOOK_PORT=8080

# ──────────────────────────────────────────────
# INTEGRATIONS
# ──────────────────────────────────────────────

NOTION_API_KEY=your_notion_api_key_here
NOTION_DATABASE_ID=your_notion_database_id
